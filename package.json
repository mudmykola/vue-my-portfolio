{
  "name": "vue-my-portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender-route-snapshots.mjs && node scripts/generate-seo-assets.mjs",
    "preview": "vite preview",
    "prepare": "husky install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "verify": "npm run test && npm run build",
    "stage": "npm run verify && git add .",
    "deploy:worker": "npm run verify && cd worker && npx wrangler deploy",
    "sync:dev": "git checkout feature/VMP_dev && git pull origin feature/VMP_dev && git merge --no-edit origin/master && git push origin feature/VMP_dev"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,vue,scss,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/vue-fontawesome": "^3.0.6",
    "@vueuse/core": "^10.9.0",
    "axios": "^1.6.8",
    "fs-extra": "^11.2.0",
    "pinia": "^2.1.7",
    "swiper": "^11.0.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "postcss": "^8.4.35",
    "prettier": "^3.3.3",
    "sass": "^1.72.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.5"
  }
}
